# ===== Konfigurasi Server =====
PORT=4000

# ===== Konfigurasi Hyperledger Fabric =====
# Nama channel pada test-network
FABRIC_CHANNEL=mychannel
# Nama chaincode yang sudah di-deploy
FABRIC_CHAINCODE=plasma-nutfah
# MSP organisasi
FABRIC_MSP_ID=Org1MSP
# Path ke connection profile (gateway) test-network Org1
FABRIC_CONNECTION_PROFILE=../fabric-samples/test-network/organizations/peerOrganizations/org1.example.com/connection-org1.json
# Direktori wallet untuk menyimpan identitas
FABRIC_WALLET_PATH=./wallet
# Identitas default yang dipakai backend untuk submit transaksi
FABRIC_IDENTITY=appUser
# Path ke materi kripto admin Org1 (untuk enroll/registrasi identitas)
FABRIC_CA_CERT_PATH=../fabric-samples/test-network/organizations/peerOrganizations/org1.example.com

# Mode SIMULASI: jika true, backend berjalan tanpa jaringan Fabric
# (transaksi blockchain ditiru/di-mock). Berguna untuk pengembangan UI
# sebelum jaringan Fabric tersedia. Set ke false saat jaringan siap.
FABRIC_MOCK=true

# ===== Konfigurasi Database Off-Chain =====
DB_STORAGE=./data/plasma_nutfah.sqlite
